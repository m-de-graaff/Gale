// Blog index page — lists all blog posts.
//
// Demonstrates: SSR, layout composition, head metadata, linking.

out ui BlogIndex {
  head {
    title: "My Blog"
    description: "A blog built with GaleX"
  }

  <main>
    <h1>"My Blog"</h1>
    <p>"Welcome to my blog built with GaleX."</p>

    <article>
      <h2><a href="/posts/hello-world">"Hello, World!"</a></h2>
      <p>"An introduction to building websites with GaleX."</p>
      <time>"2026-03-18"</time>
    </article>
  </main>
}
