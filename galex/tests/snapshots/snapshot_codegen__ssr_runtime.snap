//! SSR runtime helpers.
//!
//! Generated by GaleX compiler — do not edit manually.


/// Escape a string for safe embedding in HTML content.
pub fn escape_html(s: &str) -> String {
    s.replace('&', "&amp;")
        .replace('<', "&lt;")
        .replace('>', "&gt;")
        .replace('"', "&quot;")
        .replace('\'', "&#39;")
}
