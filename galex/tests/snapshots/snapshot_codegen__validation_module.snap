//! Shared validation types.
//!
//! Generated by GaleX compiler — do not edit manually.


use serde::Serialize;

/// A single field-level validation error.
#[derive(Debug, Clone, Serialize)]
pub struct ValidationError {
    pub field: String,
    pub message: String,
}

impl ValidationError {
    /// Create a new validation error for the given field.
    pub fn new(field: &str, message: &str) -> Self {
        Self {
            field: field.to_string(),
            message: message.to_string(),
        }
    }
}


/// Trait for types that can be validated against constraints.
pub trait Validate {
    /// Check all constraints and return any validation errors.
    fn validate(&self) -> Result<(), Vec<ValidationError>>;
}

/// Trait for types that have input transforms (trim, precision, defaults).
pub trait Sanitize {
    /// Apply transforms to the input in place before validation.
    fn sanitize(&mut self);
}
