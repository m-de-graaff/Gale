        {
          "name": "keyword.control.assert.gale",
          "match": "\\b(assert)\\b"
        }
      ]
    },

    "keywords-binding": {
      "patterns": [
        {
          "name": "meta.binding.gale",
          "match": "\\b(let|mut)\\s+([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.binding.gale" },
            "2": { "name": "variable.other.readwrite.gale" }
          }
        },
        {
          "name": "keyword.declaration.binding.gale",
          "match": "\\b(let|mut|ref)\\b"
        }
      ]
    },

    "keywords-reactive": {
      "patterns": [
        {
          "name": "keyword.control.reactive.effect.gale",
          "match": "\\b(effect)\\b"
        },
        {
          "name": "keyword.control.reactive.watch.gale",
          "match": "\\b(watch)\\b"
        }
      ]
    },

    "keywords-other": {
      "patterns": [
        {
          "name": "keyword.other.redirect.gale",
          "match": "\\b(redirect)\\b"
        },
        {
          "name": "keyword.other.link.gale",
          "match": "\\b(link)\\b"
        },
        {
          "name": "keyword.other.transition.gale",
          "match": "\\b(transition)\\b(?!:)"
        },
        {
          "name": "keyword.other.head.gale",
          "match": "\\b(head)\\b"
        }
      ]
    },

    "function-call": {
      "name": "meta.function-call.gale",
      "begin": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.gale" },
        "2": { "name": "punctuation.definition.arguments.begin.gale" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.arguments.end.gale" }
      },
      "patterns": [
        { "include": "#expression" },
        { "match": ",", "name": "punctuation.separator.comma.gale" }
      ]
    },

    "type-name": {
      "match": "\\b([A-Z][a-zA-Z0-9]*)\\b",
      "name": "entity.name.type.gale"
    },

    "identifiers": {
      "match": "\\b[a-z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.readwrite.gale"
    }
  }
}