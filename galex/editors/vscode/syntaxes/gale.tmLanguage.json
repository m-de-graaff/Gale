{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GaleX",
  "scopeName": "source.gale",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#template-literals" },
    { "include": "#numbers" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-control" },
    { "include": "#keywords-binding" },
    { "include": "#keywords-boundary" },
    { "include": "#keywords-reactive" },
    { "include": "#keywords-template" },
    { "include": "#keywords-module" },
    { "include": "#keywords-other" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#directives" },
    { "include": "#html-tags" },
    { "include": "#types" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.gale", "match": "//.*$" },
        { "name": "comment.block.gale", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.gale", "begin": "\"", "end": "\"", "patterns": [
          { "name": "constant.character.escape.gale", "match": "\\\\." }
        ]},
        { "name": "string.quoted.single.gale", "begin": "'", "end": "'", "patterns": [
          { "name": "constant.character.escape.gale", "match": "\\\\." }
        ]}
      ]
    },
    "template-literals": {
      "name": "string.template.gale",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "meta.template.expression.gale",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.gale" } },
          "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.gale" } },
          "patterns": [{ "include": "source.gale" }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.gale", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.integer.gale", "match": "\\b\\d+\\b" }
      ]
    },
    "keywords-declaration": {
      "match": "\\b(guard|action|query|store|channel|type|enum|test|middleware|env)\\b",
      "name": "keyword.declaration.gale"
    },
    "keywords-control": {
      "match": "\\b(fn|return|if|else|for|await|assert)\\b",
      "name": "keyword.control.gale"
    },
    "keywords-binding": {
      "match": "\\b(let|mut|signal|derive|frozen|ref)\\b",
      "name": "keyword.binding.gale"
    },
    "keywords-boundary": {
      "match": "\\b(server|client|shared)\\b",
      "name": "keyword.boundary.gale"
    },
    "keywords-reactive": {
      "match": "\\b(effect|watch)\\b",
      "name": "keyword.reactive.gale"
    },
    "keywords-template": {
      "match": "\\b(when|each|suspend|slot|empty)\\b",
      "name": "keyword.template.gale"
    },
    "keywords-module": {
      "match": "\\b(use|out|ui|api|layout|from)\\b",
      "name": "keyword.module.gale"
    },
    "keywords-other": {
      "match": "\\b(head|redirect|link|transition|on|bind)\\b",
      "name": "keyword.other.gale"
    },
    "constants": {
      "match": "\\b(true|false|null)\\b",
      "name": "constant.language.gale"
    },
    "operators": {
      "match": "(=>|->|<->|\\|>|\\.\\.|\\?\\?|&&|\\|\\||==|!=|<=|>=|\\+=|-=)",
      "name": "keyword.operator.gale"
    },
    "directives": {
      "match": "\\b(bind|on|class|ref|transition|key|into|form):",
      "name": "entity.other.attribute-name.directive.gale"
    },
    "html-tags": {
      "patterns": [
        {
          "match": "</([a-zA-Z][a-zA-Z0-9-]*)>",
          "captures": { "1": { "name": "entity.name.tag.gale" } }
        },
        {
          "match": "<([a-zA-Z][a-zA-Z0-9-]*)",
          "captures": { "1": { "name": "entity.name.tag.gale" } }
        }
      ]
    },
    "types": {
      "match": "\\b(string|int|float|bool|void|never|null|HTMLElement|Event)\\b",
      "name": "support.type.primitive.gale"
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": { "1": { "name": "entity.name.function.gale" } }
    },
    "identifiers": {
      "match": "\\b[A-Z][a-zA-Z0-9]*\\b",
      "name": "entity.name.type.gale"
    }
  }
}
