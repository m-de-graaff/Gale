{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GaleX",
  "scopeName": "source.gale",
  "fileTypes": ["gale", "galex"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#import-statement" },
    { "include": "#guard-block" },
    { "include": "#boundary-block" },
    { "include": "#component-block" },
    { "include": "#action-declaration" },
    { "include": "#store-block" },
    { "include": "#channel-block" },
    { "include": "#layout-block" },
    { "include": "#enum-block" },
    { "include": "#type-alias" },
    { "include": "#middleware-block" },
    { "include": "#test-block" },
    { "include": "#fn-declaration" },
    { "include": "#env-block" },
    { "include": "#expression" }
  ],
  "repository": {

    "expression": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#template-literals" },
        { "include": "#numbers" },
        { "include": "#constants" },
        { "include": "#arrow-function" },
        { "include": "#keywords-control" },
        { "include": "#keywords-binding" },
        { "include": "#keywords-reactive" },
        { "include": "#keywords-other" },
        { "include": "#types" },
        { "include": "#operators" },
        { "include": "#spread-operator" },
        { "include": "#optional-chaining" },
        { "include": "#validator-chain" },
        { "include": "#function-call" },
        { "include": "#type-name" },
        { "include": "#punctuation" },
        { "include": "#identifiers" }
      ]
    },

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.gale",
          "match": "(//).*$",
          "captures": {
            "1": { "name": "punctuation.definition.comment.gale" }
          }
        },
        {
          "name": "comment.block.gale",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.gale" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.gale" } },
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.gale",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.gale" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.gale" } },
          "patterns": [
            { "include": "#string-escapes" }
          ]
        },
        {
          "name": "string.quoted.single.gale",
          "begin": "'",
          "end": "'",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.gale" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.gale" } },
          "patterns": [
            { "include": "#string-escapes" }
          ]
        }
      ]
    },

    "string-escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.gale",
          "match": "\\\\(?:[\\\\\"'nrtbf0]|u\\{[0-9a-fA-F]{1,6}\\}|u[0-9a-fA-F]{4}|x[0-9a-fA-F]{2})"
        },
        {
          "name": "invalid.illegal.unknown-escape.gale",
          "match": "\\\\[^\\\\\"'nrtbf0ux]"
        }
      ]
    },

    "template-literals": {
      "name": "string.template.gale",
      "begin": "`",
      "end": "`",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.template.begin.gale" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.template.end.gale" } },
      "patterns": [
        { "include": "#template-substitution" },
        { "include": "#string-escapes" }
      ]
    },

    "template-substitution": {
      "name": "meta.template.expression.gale",
      "begin": "\\$\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.gale" } },
      "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.gale" } },
      "patterns": [
        { "include": "#expression" }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.gale",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.octal.gale",
          "match": "\\b0[oO][0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.binary.gale",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "name": "constant.numeric.float.gale",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?\\b"
        },
        {
          "name": "constant.numeric.float.gale",
          "match": "\\b\\d[\\d_]*[eE][+-]?\\d[\\d_]*\\b"
        },
        {
          "name": "constant.numeric.integer.gale",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.gale",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.gale",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.null.gale",
          "match": "\\bnull\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.gale",
          "match": "\\b(string|int|float|bool|void|never)\\b"
        },
        {
          "name": "support.type.builtin.gale",
          "match": "\\b(HTMLElement|Event)\\b"
        }
      ]
    },

    "type-annotation": {
      "patterns": [
        {
          "name": "meta.type.annotation.gale",
          "begin": ":\\s*",
          "end": "(?=[=,\\)\\}\\]\\{;\\n]|\\s*[\\)\\}\\]>])",
          "beginCaptures": { "0": { "name": "keyword.operator.type.annotation.gale" } },
          "patterns": [
            { "include": "#type-expression" }
          ]
        }
      ]
    },

    "type-expression": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#types" },
        {
          "name": "keyword.operator.type.union.gale",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.type.intersection.gale",
          "match": "&"
        },
        {
          "name": "keyword.operator.type.optional.gale",
          "match": "\\?"
        },
        {
          "match": "\\b([A-Z][a-zA-Z0-9]*)\\b",
          "name": "entity.name.type.gale"
        },
        {
          "begin": "<",
          "end": ">",
          "beginCaptures": { "0": { "name": "punctuation.definition.typeparameters.begin.gale" } },
          "endCaptures": { "0": { "name": "punctuation.definition.typeparameters.end.gale" } },
          "patterns": [
            { "include": "#type-expression" },
            { "match": ",", "name": "punctuation.separator.comma.gale" }
          ]
        },
        {
          "begin": "\\[",
          "end": "\\]",
          "beginCaptures": { "0": { "name": "punctuation.definition.array.begin.gale" } },
          "endCaptures": { "0": { "name": "punctuation.definition.array.end.gale" } },
          "patterns": [
            { "include": "#type-expression" }
          ]
        },
        {
          "begin": "\\(",
          "end": "\\)",
          "beginCaptures": { "0": { "name": "punctuation.definition.tuple.begin.gale" } },
          "endCaptures": { "0": { "name": "punctuation.definition.tuple.end.gale" } },
          "patterns": [
            { "include": "#type-expression" },
            { "match": ",", "name": "punctuation.separator.comma.gale" }
          ]
        },
        {
          "name": "keyword.operator.arrow.return-type.gale",
          "match": "->"
        },
        {
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b",
          "name": "variable.other.type.gale"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.fat-arrow.gale",
          "match": "=>"
        },
        {
          "name": "keyword.operator.arrow.gale",
          "match": "->"
        },
        {
          "name": "keyword.operator.bidirectional.gale",
          "match": "<->"
        },
        {
          "name": "keyword.operator.pipe.gale",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.range.gale",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.nullish-coalescing.gale",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.logical.and.gale",
          "match": "&&"
        },
        {
          "name": "keyword.operator.logical.or.gale",
          "match": "\\|\\|"
        },
        {
          "name": "keyword.operator.comparison.equality.gale",
          "match": "==|!="
        },
        {
          "name": "keyword.operator.comparison.relational.gale",
          "match": "<=|>="
        },
        {
          "name": "keyword.operator.comparison.relational.gale",
          "match": "(?<!=|!|<|>)[<>](?!=|>|<)"
        },
        {
          "name": "keyword.operator.assignment.compound.gale",
          "match": "\\+=|-="
        },
        {
          "name": "keyword.operator.assignment.gale",
          "match": "=(?!=|>)"
        },
        {
          "name": "keyword.operator.logical.not.gale",
          "match": "!(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.gale",
          "match": "[+\\-*/%]"
        }
      ]
    },

    "spread-operator": {
      "name": "keyword.operator.spread.gale",
      "match": "\\.\\.\\."
    },

    "optional-chaining": {
      "name": "keyword.operator.optional-chaining.gale",
      "match": "\\?\\."
    },

    "punctuation": {
      "patterns": [
        { "match": ";", "name": "punctuation.terminator.statement.gale" },
        { "match": ",", "name": "punctuation.separator.comma.gale" },
        { "match": "\\.", "name": "punctuation.accessor.gale" }
      ]
    },

    "import-statement": {
      "name": "meta.import.gale",
      "begin": "\\b(use)\\b",
      "end": "(?<=;)|(?<=\"[^\"]*\")|(?<='[^']*')|$",
      "beginCaptures": {
        "1": { "name": "keyword.control.import.gale" }
      },
      "patterns": [
        { "include": "#comments" },
        {
          "name": "meta.import.names.gale",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.definition.block.begin.gale" } },
          "endCaptures": { "0": { "name": "punctuation.definition.block.end.gale" } },
          "patterns": [
            { "include": "#comments" },
            {
              "match": "\\b([A-Z][a-zA-Z0-9]*)\\b",
              "name": "entity.name.type.import.gale"
            },
            {
              "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b",
              "name": "variable.other.import.gale"
            },
            { "match": ",", "name": "punctuation.separator.comma.gale" }
          ]
        },
        {
          "match": "\\b([A-Z][a-zA-Z0-9]*)\\b(?!\\s*\\{)",
          "name": "entity.name.type.import.gale"
        },
        {
          "name": "keyword.control.from.gale",
          "match": "\\b(from)\\b"
        },
        { "include": "#strings" }
      ]
    },

    "guard-block": {
      "name": "meta.guard.gale",
      "begin": "\\b(guard)\\s+([A-Z][a-zA-Z0-9]*)\\s*(\\{)",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.guard.gale" },
        "2": { "name": "entity.name.type.guard.gale" },
        "3": { "name": "punctuation.definition.block.begin.gale" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.block.end.gale" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#guard-field" }
      ]
    },

    "guard-field": {
      "name": "meta.guard.field.gale",
      "begin": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(:)\\s*",
      "end": "(?=\\}|\\b[a-z_][a-zA-Z0-9_]*\\s*:)",
      "beginCaptures": {
        "1": { "name": "variable.other.property.guard-field.gale" },
        "2": { "name": "punctuation.separator.key-value.gale" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#guard-field-type" },
        { "include": "#validator-chain" }
      ]
    },

    "guard-field-type": {
      "patterns": [
        {
          "name": "support.type.primitive.gale",
          "match": "\\b(string|int|float|bool|void|never)\\b"
        },
        {
          "match": "\\b([A-Z][a-zA-Z0-9]*)\\b",
          "name": "entity.name.type.gale"
        },
        {
          "name": "keyword.operator.type.optional.gale",
          "match": "\\?"
        }
      ]
    },

    "validator-chain": {
      "name": "meta.validator-chain.gale",
      "begin": "(?<=\\b(?:string|int|float|bool|void|never|[A-Z][a-zA-Z0-9]*)\\??)\\s*(\\.)",
      "end": "(?=[\\s\\}\\),;]|$)",
      "beginCaptures": {
        "1": { "name": "punctuation.accessor.validator.gale" }
      },
      "patterns": [
        { "include": "#validator-method" }
      ]
    },

    "validator-method": {
      "patterns": [
        {
          "name": "meta.validator.method-call.gale",
          "begin": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "end": "\\)",
          "beginCaptures": {
            "1": { "name": "entity.name.function.validator.gale" },
            "2": { "name": "punctuation.definition.arguments.begin.gale" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.arguments.end.gale" }
          },
          "patterns": [
            { "include": "#expression" }
          ]
        },
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*(?:\\.|$|[\\s\\}\\),;]))",
          "captures": {
            "1": { "name": "entity.name.function.validator.gale" }
          }
        },
        {
          "match": "\\.",
          "name": "punctuation.accessor.validator.gale"
        }
      ]
    },

    "boundary-block": {
      "name": "meta.boundary.gale",
      "begin": "\\b(server|client|shared)\\s*(\\{)",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "keyword.control.boundary.gale" },
        "2": { "name": "punctuation.definition.block.begin.gale" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.block.end.gale" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#import-statement" },
        { "include": "#action-declaration" },
        { "include": "#fn-declaration" },
        { "include": "#query-declaration" },
        { "include": "#store-block" },
        { "include": "#channel-block" },
        { "include": "#middleware-block" },
        { "include": "#env-block" },
        { "include": "#expression" }
      ]
    },

    "component-block": {
      "name": "meta.component.gale",
      "begin": "\\b(out)\\s+(ui|api)\\s+([A-Z][a-zA-Z0-9]*)\\s*(\\{)",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.export.gale" },
        "2": { "name": "keyword.declaration.component-kind.gale" },
        "3": { "name": "entity.name.type.component.gale" },
        "4": { "name": "punctuation.definition.block.begin.gale" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.block.end.gale" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#head-block" },
        { "include": "#component-signal" },
        { "include": "#component-derive" },
        { "include": "#component-effect" },
        { "include": "#component-watch" },
        { "include": "#fn-declaration" },
        { "include": "#template-region" }
      ]
    },

    "head-block": {
      "name": "meta.head.gale",
      "begin": "\\b(head)\\s*(\\{)",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "keyword.other.head.gale" },
        "2": { "name": "punctuation.definition.block.begin.gale" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.block.end.gale" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#template-region" }
      ]
    },

    "component-signal": {
      "name": "meta.signal.gale",
      "begin": "\\b(signal|frozen)\\s+([a-z_][a-zA-Z0-9_]*)\\b",
      "end": "(?=\\n|;|\\})",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.signal.gale" },
        "2": { "name": "variable.other.signal.gale" }
      },
      "patterns": [
        { "include": "#type-annotation" },
        { "include": "#expression" }
      ]
    },

    "component-derive": {
      "name": "meta.derive.gale",
      "begin": "\\b(derive)\\s+([a-z_][a-zA-Z0-9_]*)\\b",
      "end": "(?=\\n|;|\\})",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.derive.gale" },
        "2": { "name": "variable.other.derived.gale" }
      },
      "patterns": [
        { "include": "#type-annotation" },
        { "include": "#expression" }
      ]
    },

    "component-effect": {
      "name": "meta.effect.gale",
      "begin": "\\b(effect)\\b",
      "end": "(?<=\\})",
      "beginCaptures": {
        "1": { "name": "keyword.control.effect.gale" }
      },
      "patterns": [
        { "include": "#expression" },
        { "include": "#block-body" }
      ]
    },

    "component-watch": {
      "name": "meta.watch.gale",
      "begin": "\\b(watch)\\b",
      "end": "(?<=\\})",
      "beginCaptures": {
        "1": { "name": "keyword.control.watch.gale" }
      },
      "patterns": [
        { "include": "#expression" },
        { "include": "#block-body" }
      ]
    },

    "template-region": {
      "patterns": [
        { "include": "#template-interpolation" },
        { "include": "#template-control-when" },
        { "include": "#template-control-each" },
        { "include": "#template-control-suspend" },
        { "include": "#html-self-closing-tag" },
        { "include": "#html-open-tag" },
        { "include": "#html-close-tag" },
        { "include": "#component-tag-self-closing" },
        { "include": "#component-tag-open" },
        { "include": "#component-tag-close" },
        { "include": "#slot-tag" },
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#expression" }
      ]
    },

    "template-interpolation": {
      "name": "meta.interpolation.gale",
      "begin": "(?<!\\$)(\\{)(?!\\{)",
      "end": "\\}",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.interpolation.begin.gale" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.interpolation.end.gale" }
      },
      "patterns": [
        { "include": "#expression" }
      ]
    },

    "template-control-when": {
      "name": "meta.control.when.gale",
      "begin": "\\{(when)\\s",
      "end": "\\{/(when)\\}",
      "beginCaptures": {
        "1": { "name": "keyword.control.when.gale" }
      },
      "endCaptures": {
        "1": { "name": "keyword.control.when.gale" }
      },
      "patterns": [
        {
          "match": "\\{(else)(?:\\s+(when))?\\b",
          "captures": {
            "1": { "name": "keyword.control.else.gale" },
            "2": { "name": "keyword.control.when.gale" }
          }
        },
        { "include": "#template-region" },
        { "include": "#expression" }
      ]
    },

    "template-control-each": {
      "name": "meta.control.each.gale",
      "begin": "\\{(each)\\s",
      "end": "\\{/(each)\\}",
      "beginCaptures": {
        "1": { "name": "keyword.control.each.gale" }
      },
      "endCaptures": {
        "1": { "name": "keyword.control.each.gale" }
      },
      "patterns": [
        {
          "name": "keyword.control.empty.gale",
          "match": "\\{(empty)\\}",
          "captures": {
            "1": { "name": "keyword.control.empty.gale" }
          }
        },
        { "include": "#template-region" },
        { "include": "#expression" }
      ]
    },

    "template-control-suspend": {
      "name": "meta.control.suspend.gale",
      "begin": "\\{(suspend)\\s",
      "end": "\\{/(suspend)\\}",
      "beginCaptures": {
        "1": { "name": "keyword.control.suspend.gale" }
      },
      "endCaptures": {
        "1": { "name": "keyword.control.suspend.gale" }
      },
      "patterns": [
        { "include": "#template-region" },
        { "include": "#expression" }
      ]
    },

    "slot-tag": {
      "patterns": [
        {
          "name": "meta.tag.slot.self-closing.gale",
          "match": "<(slot)\\s*(/?)>",
          "captures": {
            "1": { "name": "keyword.control.slot.gale" },
            "2": { "name": "punctuation.definition.tag.self-closing.gale" }
          }
        },
        {
          "name": "meta.tag.slot.open.gale",
          "begin": "<(slot)(?=\\s|>)",
          "end": ">",
          "beginCaptures": {
            "1": { "name": "keyword.control.slot.gale" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.tag.end.gale" }
          },
          "patterns": [
            { "include": "#tag-attributes" }
          ]
        },
        {
          "name": "meta.tag.slot.close.gale",
          "match": "</(slot)>",
          "captures": {
            "1": { "name": "keyword.control.slot.gale" }
          }
        }
      ]
    },

    "html-open-tag": {
      "name": "meta.tag.open.gale",
      "begin": "(<)([a-z][a-z0-9]*(?:-[a-z0-9]+)*)(?=\\s|>|/)",
      "end": "(/?>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.gale" },
